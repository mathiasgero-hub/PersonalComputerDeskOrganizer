<Window x:Class="PersonalComputerDeskOrganizer.Views.DesktopCountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nouveau profil"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="420" Height="260"
        Background="{StaticResource DecoCharcoal}"
        BorderBrush="{StaticResource DecoGold}" BorderThickness="1">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="COMBIEN DE BUREAUX ?" FontFamily="{StaticResource DecoDisplayFont}"
                   FontSize="16" Foreground="{StaticResource DecoGoldLight}" Margin="0,0,0,24"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
            <Button Content="−" Width="36" Height="36" Style="{StaticResource DecoIconButton}" Click="Minus_Click"/>
            <TextBlock x:Name="CountText" Text="4" Width="60" FontSize="24" FontFamily="{StaticResource DecoDisplayFont}"
                       Foreground="{StaticResource DecoGoldLight}" TextAlignment="Center" VerticalAlignment="Center"/>
            <Button Content="+" Width="36" Height="36" Style="{StaticResource DecoIconButton}" Click="Plus_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ANNULER" Style="{StaticResource DecoGhostButton}" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="CONTINUER" Style="{StaticResource DecoGoldButton}" Click="Continue_Click"/>
        </StackPanel>
    </Grid>
</Window>
