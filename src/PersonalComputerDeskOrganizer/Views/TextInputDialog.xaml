<Window x:Class="PersonalComputerDeskOrganizer.Views.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PersonalComputerDeskOrganizer"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="440" Height="190"
        Background="{StaticResource DecoCharcoal}"
        BorderBrush="{StaticResource DecoGold}" BorderThickness="1">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0" Text="Adresse :" FontFamily="{StaticResource DecoDisplayFont}"
                   FontSize="13" Foreground="{StaticResource DecoGoldLight}" Margin="0,0,0,14"/>

        <TextBox x:Name="ValueTextBox" Grid.Row="1" Style="{StaticResource DecoTextBox}" Margin="0,0,0,8"
                 KeyDown="ValueTextBox_KeyDown"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ANNULER" Style="{StaticResource DecoGhostButton}" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="VALIDER" Style="{StaticResource DecoGoldButton}" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
