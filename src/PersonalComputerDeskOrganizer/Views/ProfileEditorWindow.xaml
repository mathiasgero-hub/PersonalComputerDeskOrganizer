<Window x:Class="PersonalComputerDeskOrganizer.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PersonalComputerDeskOrganizer — Configuration"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="{StaticResource DecoBlack}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- top bar -->
        <Border Grid.Row="0" Background="{StaticResource DecoCharcoal}"
                BorderBrush="{StaticResource DecoGoldDim}" BorderThickness="0,0,0,1">
            <Grid Margin="28,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="‹ retour aux profils" Style="{StaticResource DecoGhostButton}"
                        Margin="0,0,24,0" Click="Back_Click"/>

                <TextBlock Grid.Column="1" Text="PROFIL" Style="{StaticResource DecoLabel}"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                <TextBox Grid.Column="2" x:Name="ProfileNameTextBox" Style="{StaticResource DecoTextBox}"
                         MaxWidth="380" HorizontalAlignment="Left" FontFamily="{StaticResource DecoDisplayFont}"
                         FontSize="16" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,28,0">
                    <TextBlock Text="BUREAUX" Style="{StaticResource DecoLabel}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="−" Width="26" Height="26" Style="{StaticResource DecoIconButton}" Click="DeskCountMinus_Click"/>
                    <TextBlock x:Name="DeskCountText" Text="4" Width="32" TextAlignment="Center" VerticalAlignment="Center"
                               FontFamily="{StaticResource DecoDisplayFont}" Foreground="{StaticResource DecoGoldLight}"/>
                    <Button Content="+" Width="26" Height="26" Style="{StaticResource DecoIconButton}" Click="DeskCountPlus_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="ANNULER" Style="{StaticResource DecoGhostButton}" Margin="0,0,12,0" Click="Cancel_Click"/>
                    <Button Content="CRÉER LE PROFIL" Style="{StaticResource DecoGoldButton}" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="Cliquez sur une icône de disposition pour diviser un bureau, puis choisissez une application, un fichier ou une URL pour chaque zone."
                   Foreground="{StaticResource DecoTextMuted}" FontSize="12" HorizontalAlignment="Center" Margin="0,16"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="DeskGridPanel" Margin="36" HorizontalAlignment="Center"/>
        </ScrollViewer>

    </Grid>
</Window>
