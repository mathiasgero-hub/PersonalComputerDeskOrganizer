<Window x:Class="PersonalComputerDeskOrganizer.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PersonalComputerDeskOrganizer"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="{StaticResource DecoBlack}">

    <Grid>

        <!-- corner ornaments -->
        <Path Data="M2,90 A88,88 0 0 1 90,2 M2,74 A72,72 0 0 1 74,2 M2,58 A56,56 0 0 1 58,2 M2,42 A40,40 0 0 1 42,2"
              Stroke="{StaticResource DecoGold}" StrokeThickness="1.4"
              HorizontalAlignment="Left" VerticalAlignment="Top" Margin="26"/>
        <Path Data="M2,90 A88,88 0 0 1 90,2 M2,74 A72,72 0 0 1 74,2 M2,58 A56,56 0 0 1 58,2 M2,42 A40,40 0 0 1 42,2"
              Stroke="{StaticResource DecoGold}" StrokeThickness="1.4"
              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="26">
            <Path.RenderTransform><ScaleTransform ScaleX="-1"/></Path.RenderTransform>
        </Path>
        <Path Data="M2,90 A88,88 0 0 1 90,2 M2,74 A72,72 0 0 1 74,2 M2,58 A56,56 0 0 1 58,2 M2,42 A40,40 0 0 1 42,2"
              Stroke="{StaticResource DecoGold}" StrokeThickness="1.4"
              HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="26">
            <Path.RenderTransform><ScaleTransform ScaleY="-1"/></Path.RenderTransform>
        </Path>
        <Path Data="M2,90 A88,88 0 0 1 90,2 M2,74 A72,72 0 0 1 74,2 M2,58 A56,56 0 0 1 58,2 M2,42 A40,40 0 0 1 42,2"
              Stroke="{StaticResource DecoGold}" StrokeThickness="1.4"
              HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="26">
            <Path.RenderTransform><ScaleTransform ScaleX="-1" ScaleY="-1"/></Path.RenderTransform>
        </Path>

        <!-- quit + settings buttons, top-right, deliberately understated -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,40,40,0">
            <Button Content="⚙" Click="Settings_Click" Style="{StaticResource DecoIconButton}" Margin="0,0,8,0"/>
            <Button Content="✕" Click="Quit_Click" Style="{StaticResource DecoIconButton}"/>
        </StackPanel>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="900">

            <TextBlock Text="bienvenue" Style="{StaticResource DecoLabel}"
                       HorizontalAlignment="Center" Margin="0,0,0,14"/>

            <TextBlock Text="PERSONAL COMPUTER&#x0a;DESK ORGANIZER"
                       FontFamily="{StaticResource DecoDisplayFont}"
                       FontSize="42" FontWeight="SemiBold"
                       TextAlignment="Center" HorizontalAlignment="Center"
                       Margin="0,0,0,40">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#E9CF6E" Offset="0"/>
                        <GradientStop Color="#C9A227" Offset="0.45"/>
                        <GradientStop Color="#8A7220" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>

            <ItemsControl x:Name="ProfilesItemsControl" Margin="0,0,0,56">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="160" Margin="20,0">
                            <Grid Width="108" Height="108" HorizontalAlignment="Center" Margin="0,0,0,16"
                                  MouseLeftButtonUp="ProfileAvatar_Click" Cursor="Hand">
                                <Ellipse Width="108" Height="108" Stroke="{StaticResource DecoGold}" StrokeThickness="2"
                                         Fill="{StaticResource DecoCharcoal2}"/>
                                <TextBlock Text="{Binding Initial}" FontFamily="{StaticResource DecoDisplayFont}"
                                           FontSize="30" Foreground="{StaticResource DecoGoldLight}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                                <Button Content="•••" FontSize="9" Padding="0"
                                        Width="26" Height="26" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-6,-4,0" Style="{StaticResource DecoIconButton}"
                                        Click="ProfileMenu_Click">
                                    <Button.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Éditer" Click="EditProfile_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Supprimer" Click="DeleteProfile_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </Grid>
                            <TextBlock Text="{Binding Name}" FontFamily="{StaticResource DecoBodyFont}"
                                       FontSize="13" Foreground="{StaticResource DecoText}"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="+ NOUVEAU PROFIL" Style="{StaticResource DecoGoldButton}"
                    HorizontalAlignment="Center" Click="NewProfile_Click"/>

        </StackPanel>

    </Grid>
</Window>
