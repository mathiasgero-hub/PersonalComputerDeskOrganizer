<Window x:Class="PersonalComputerDeskOrganizer.Views.LaunchOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PersonalComputerDeskOrganizer"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        Width="480" Height="140"
        Background="{StaticResource DecoCharcoal}"
        BorderBrush="{StaticResource DecoGold}" BorderThickness="1">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="LANCEMENT DU PROFIL" FontFamily="{StaticResource DecoDisplayFont}"
                   FontSize="14" Foreground="{StaticResource DecoGoldLight}" Margin="0,0,0,14"/>
        <TextBlock x:Name="StatusText" Grid.Row="1" Text="Préparation…" FontFamily="{StaticResource DecoBodyFont}"
                   FontSize="13" Foreground="{StaticResource DecoText}" TextWrapping="Wrap"/>
    </Grid>
</Window>
